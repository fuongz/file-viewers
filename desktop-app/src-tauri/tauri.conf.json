{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "File Viewers",
  "version": "0.4.1",
  "identifier": "com.fuongz.file-viewers",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "transparent": true,
        "title": "File Viewers",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "width": 1200,
        "height": 760,
        "minWidth": 640,
        "minHeight": 400,
        "devtools": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
