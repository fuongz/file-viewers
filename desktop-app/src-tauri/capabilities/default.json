{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Main window capability",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"core:event:default",
		"core:window:allow-start-dragging",
		"opener:default",
		"dialog:allow-open",
		"fs:allow-read-text-file",
		"fs:allow-write-text-file",
		"fs:scope-home-recursive"
	]
}
