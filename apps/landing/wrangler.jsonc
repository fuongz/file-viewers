{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "prod-file-viewers",
	"compatibility_date": "2026-03-03",
	"compatibility_flags": ["nodejs_compat"],
	"main": "@tanstack/react-start/server-entry",
	"workers_dev": false,
	"preview_urls": false,
	"routes": [
		{
			"pattern": "files.phake.app",
			"custom_domain": true
		}
	]
}
